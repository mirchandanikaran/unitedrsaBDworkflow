# Set to 0 for unbounded link extraction per portal.
NIC_MAX_LINKS_PER_PORTAL=0
INTL_MAX_LINKS_PER_PORTAL=0
ADDITIONAL_MAX_LINKS_PER_PORTAL=0
BENCHMARK_MAX_MISSING_ORG_PCT=5
BENCHMARK_MAX_MISSING_COUNTRY_PCT=5
BENCHMARK_MAX_MISSING_CLOSING_PCT=70
# Soft cap for one ingestion run. Set to 0 for no runtime cap.
INGESTION_TIME_BUDGET_SECONDS=1800
