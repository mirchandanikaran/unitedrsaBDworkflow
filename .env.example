DATABASE_URL=postgresql://user:password@localhost:5432/tender_intel
LOG_LEVEL=INFO
CONNECTOR_TIMEOUT_SECONDS=20
CONNECTOR_RETRY_ATTEMPTS=3
CONNECTOR_USER_AGENT=TenderIntelBot/1.0
PLAYWRIGHT_FALLBACK=true
TED_API_URL=https://api.ted.europa.eu/v3/notices/search
TED_PAGE_SIZE=250
# Set to 0 for unbounded pagination until source exhausts.
TED_MAX_PAGES=0
TED_QUERY=publication-date>=20240101
CPPP_BASE_URL=https://eprocure.gov.in/eprocure/app
CPPP_MAX_ORG_LINKS=0
CPPP_MAX_RESULTS=0
